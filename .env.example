# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 3001)
PORT=3001

# --- Provider keys (seeded into DB on startup, Coolify-friendly) ---
# Only set the providers you have keys for — missing vars are silently skipped.
# Google Gemini (2.5 Flash etc) — https://aistudio.google.com/apikey
FREELLMAPI_GOOGLE_KEY=
# Groq — https://console.groq.com/keys
FREELLMAPI_GROQ_KEY=
# Cerebras (Qwen3 235B) — https://cloud.cerebras.ai
FREELLMAPI_CEREBRAS_KEY=
# SambaNova (DeepSeek V3, Llama 4) — https://cloud.sambanova.ai
FREELLMAPI_SAMBANOVA_KEY=
# Mistral — https://console.mistral.ai/api-keys
FREELLMAPI_MISTRAL_KEY=
# OpenRouter (19 free-tier models) — https://openrouter.ai/keys
FREELLMAPI_OPENROUTER_KEY=
# GitHub Models (GPT-4.1, GPT-4o) — https://github.com/settings/tokens
FREELLMAPI_GITHUB_KEY=
# Cohere — https://dashboard.cohere.com/api-keys (ToS: avoid for production)
FREELLMAPI_COHERE_KEY=
# Cloudflare Workers AI — https://dash.cloudflare.com/profile/api-tokens
FREELLMAPI_CLOUDFLARE_KEY=
# Zhipu (GLM-4.5) — https://open.bigmodel.cn
FREELLMAPI_ZHIPU_KEY=
# Ollama Cloud — https://ollama.com
FREELLMAPI_OLLAMA_KEY=
